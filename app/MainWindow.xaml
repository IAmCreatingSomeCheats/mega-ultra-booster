<Window x:Class="MegaUltraBooster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚡ MEGA Ultra Booster" Height="720" Width="1000"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="13">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚡" FontSize="26" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="MEGA Ultra Booster" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Minecraft performance booster · mod + app" Foreground="{StaticResource Subtle}" FontSize="12"/>
                </StackPanel>
            </StackPanel>
            <Border x:Name="LinkPill" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{StaticResource Panel2}" CornerRadius="14" Padding="14,7">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="LinkDot" Width="10" Height="10" Fill="{StaticResource Subtle}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LinkText" Text="Waiting for mod…" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Body ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: controls -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,9,0">
                <StackPanel>

                    <!-- System Boost card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="SYSTEM BOOST" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,0,10"/>
                            <TextBlock x:Name="MemText" Text="Detecting memory…" Foreground="{StaticResource Subtle}" Margin="0,0,0,10"/>

                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="RAM for Minecraft" VerticalAlignment="Center"/>
                                <TextBlock x:Name="RamLabel" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                           FontWeight="Bold" Foreground="{StaticResource Accent}" Text="4.0 GB"/>
                            </DockPanel>
                            <Slider x:Name="RamSlider" Minimum="2048" Maximum="16384" Value="4096"
                                    TickFrequency="512" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>

                            <CheckBox x:Name="PowerToggle" Style="{StaticResource Switch}" Content="High-Performance power plan" IsChecked="True" Margin="0,5,0,0"/>
                            <CheckBox x:Name="PriorityToggle" Style="{StaticResource Switch}" Content="Set Minecraft to High priority" IsChecked="True" Margin="0,9,0,0"/>
                            <CheckBox x:Name="TrimToggle" Style="{StaticResource Switch}" Content="Free standby RAM (trim working sets)" IsChecked="True" Margin="0,9,0,0"/>
                            <CheckBox x:Name="GameModeToggle" Style="{StaticResource Switch}" Content="Enable Windows Game Mode" IsChecked="True" Margin="0,9,0,0"/>
                            <CheckBox x:Name="DynamicFpsToggle" Style="{StaticResource Switch}" Content="Dynamic FPS when unfocused (in-game)" IsChecked="True" Margin="0,9,0,12"/>

                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="Boost intensity" VerticalAlignment="Center"/>
                                <ComboBox x:Name="IntensityCombo" DockPanel.Dock="Right" Width="180" Padding="8,4"/>
                            </DockPanel>

                            <Button x:Name="BoostButton" Style="{StaticResource BoostButton}" Content="🚀  BOOST NOW" Click="BoostButton_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Launcher card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="OPTIMIZED LAUNCHER" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,0,10"/>
                            <TextBlock Text="JVM args (Aikar's flags):" Foreground="{StaticResource Subtle}" Margin="0,0,0,4"/>
                            <Border Background="{StaticResource Panel2}" CornerRadius="6" Padding="8" Margin="0,0,0,10">
                                <TextBox x:Name="FlagsText" IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                                         Background="Transparent" Foreground="{StaticResource Subtle}" FontFamily="Consolas"
                                         FontSize="11" MaxHeight="90" VerticalScrollBarVisibility="Auto"/>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="ApplyProfileButton" Content="💾  Save profile" Click="ApplyProfileButton_Click"/>
                                <Button Grid.Column="2" x:Name="LaunchButton" Content="▶  Launch Minecraft" Click="LaunchButton_Click"/>
                            </Grid>
                            <TextBlock x:Name="LauncherStatus" Text="" Foreground="{StaticResource Subtle}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Pause apps card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="PAUSE BACKGROUND APPS (optional)" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                            <TextBlock Text="Comma-separated process names (no .exe). System apps are protected." Foreground="{StaticResource Subtle}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBox x:Name="PauseNamesBox" Background="{StaticResource Panel2}" Foreground="{StaticResource Text}"
                                     BorderThickness="0" Padding="8" Text="chrome, Spotify, Discord"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="⏸  Pause" Click="PauseButton_Click"/>
                                <Button Grid.Column="2" Content="▶  Resume" Click="ResumeButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Right: telemetry + servers -->
            <Grid Grid.Column="1" Margin="9,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Live telemetry -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="LIVE (from the game)" FontWeight="Bold" Foreground="{StaticResource Good}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="FpsText" Text="—" FontSize="52" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                <TextBlock Text="FPS" Foreground="{StaticResource Subtle}" Margin="2,-8,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="FrameTimeText" Text="Frame time: —" Margin="0,0,0,6"/>
                                <TextBlock x:Name="RamUsageText" Text="Heap: —" Margin="0,0,0,4"/>
                                <ProgressBar x:Name="RamBar" Height="8" Minimum="0" Maximum="100" Value="0"
                                             Background="{StaticResource Panel2}" Foreground="{StaticResource Good}" BorderThickness="0"/>
                                <TextBlock x:Name="ServerText" Text="Server: —" Foreground="{StaticResource Subtle}" Margin="0,8,0,0"/>
                                <TextBlock x:Name="DimText" Text="Dimension: —" Foreground="{StaticResource Subtle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="FPS (recent)" Foreground="{StaticResource Subtle}" FontSize="11" Margin="0,14,0,4"/>
                        <Border Background="{StaticResource Panel2}" CornerRadius="6" Padding="6" Height="66">
                            <Canvas x:Name="FpsGraph" ClipToBounds="True"/>
                        </Border>
                        <TextBlock x:Name="FpsMinAvgMax" Text="min —  ·  avg —  ·  max —"
                                   Foreground="{StaticResource Subtle}" FontSize="11" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Smart Server Switcher -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="SMART SERVER SWITCHER" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Text="Routes you to the quietest server in a category." Foreground="{StaticResource Subtle}" FontSize="11" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>

                        <Grid Grid.Row="1" Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CategoryCombo" Grid.Column="0" Padding="8,6"/>
                            <Button x:Name="PingAllButton" Grid.Column="2" Content="📡  Ping all" Click="PingAllButton_Click"/>
                            <Button x:Name="QuietestButton" Grid.Column="4" Content="🎯  Send me to quietest" Click="QuietestButton_Click"/>
                        </Grid>

                        <DataGrid x:Name="ServersGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#11FFFFFF"
                                  BorderThickness="0" GridLinesVisibility="None" HeadersVisibility="Column"
                                  Foreground="{StaticResource Text}" RowHeight="30" CanUserAddRows="False"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="1.4*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.1*"/>
                                <DataGridTextColumn Header="Players" Binding="{Binding Players}" Width="Auto"/>
                                <DataGridTextColumn Header="Ping" Binding="{Binding PingText}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="3" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AddName" Grid.Column="0" Background="{StaticResource Panel2}" Foreground="{StaticResource Text}" BorderThickness="0" Padding="6" Margin="0,0,6,0" Tag="Name"/>
                            <TextBox x:Name="AddAddress" Grid.Column="1" Background="{StaticResource Panel2}" Foreground="{StaticResource Text}" BorderThickness="0" Padding="6" Margin="0,0,6,0" Tag="address:port"/>
                            <TextBox x:Name="AddCategory" Grid.Column="2" Background="{StaticResource Panel2}" Foreground="{StaticResource Text}" BorderThickness="0" Padding="6" Margin="0,0,6,0" Text="Casual/Beginner"/>
                            <Button x:Name="AddButton" Grid.Column="3" Content="➕ Add" Click="AddButton_Click" Margin="0,0,6,0"/>
                            <Button x:Name="RemoveButton" Grid.Column="4" Content="🗑" Click="RemoveButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Log ── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="10">
            <TextBox x:Name="LogBox" IsReadOnly="True" Background="Transparent" Foreground="{StaticResource Subtle}"
                     BorderThickness="0" FontFamily="Consolas" FontSize="11" Height="92"
                     VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"/>
        </Border>
    </Grid>
</Window>
